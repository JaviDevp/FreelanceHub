@page "/"

<PageTitle>FreelanceHub</PageTitle>

<section class="min-h-screen bg-slate-950 px-6 py-16 text-slate-100">
    <div class="mx-auto max-w-5xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-400">FreelanceHub</p>
        <h1 class="mt-4 max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl">
            Oportunidades freelance, reunidas en un solo lugar.
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
            La base técnica está lista. El feed incorporará ofertas normalizadas de múltiples plataformas.
        </p>
        <div class="mt-10 rounded-xl border border-slate-800 bg-slate-900/70 p-6 shadow-2xl shadow-cyan-950/20">
            <p class="text-sm text-slate-400">Prueba de estilos</p>
            <p class="mt-2 font-medium text-slate-100">Tailwind CSS está configurado correctamente.</p>
        </div>
    </div>
</section>
